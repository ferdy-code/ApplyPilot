# Backend environment — copy to .env and fill in. Bun auto-loads .env from be/.

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/applyPilot

# Better Auth: secret used to sign session cookies, and the base URL of this API.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8000

# Optional social sign-in. A provider is registered only when BOTH values are
# set, so email/password works without them. Create OAuth apps and set the
# callback URLs to http://localhost:8000/api/auth/callback/{github,google}.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
